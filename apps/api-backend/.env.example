# MyFinanceManager API - Environment Variables
# Copy this file to .env and update with your values

# Server Configuration
SERVER_PORT=8080

# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/mfm_db
DB_USERNAME=mfm_user
DB_PASSWORD=mfm_password

# JWT Configuration
# IMPORTANT: Change this in production! Use a strong random string (at least 32 characters)
JWT_SECRET=myfinance-manager-secret-key-for-development-only-change-in-production
JWT_EXPIRATION=86400000

# Spring Profile
SPRING_PROFILES_ACTIVE=dev